# URL do projeto (NÃO é a chave — formato: https://SEU_REF.supabase.co)
VITE_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co

# Chave pública do browser (sb_publishable_... ou, em projetos legados, anon JWT)
# Dashboard → Project Settings → API Keys → Publishable key
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_sua_chave_aqui

# Legado (opcional, se ainda não migrou para publishable):
# VITE_SUPABASE_ANON_KEY=eyJ...

# Landing (opcional — padrão: {VITE_SUPABASE_URL}/functions/v1/landing)
# VITE_LANDING_API_URL=https://SEU_PROJECT_REF.supabase.co/functions/v1/landing

# NUNCA coloque sb_secret_... ou service_role aqui (prefixo VITE_ vai para o browser).
